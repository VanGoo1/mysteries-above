{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "fallback": {
      "type": "minecraft:model",
      "model": "item/music_disc_ward"
    },
    "cases": [
      {
        "when": "active",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "fallback": {
            "type": "minecraft:model",
            "model": "item/active"
          },
          "cases": [
            {
              "when": [
                "firstperson_righthand",
                "firstperson_lefthand",
                "thirdperson_righthand",
                "thirdperson_lefthand"
              ],
              "model": {
                "type": "minecraft:model",
                "model": "item/hidden"
              }
            }
          ]
        }
      },
      {
        "when": "passive",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "fallback": {
            "type": "minecraft:model",
            "model": "item/passive"
          },
          "cases": [
            {
              "when": [
                "firstperson_righthand",
                "firstperson_lefthand",
                "thirdperson_righthand",
                "thirdperson_lefthand"
              ],
              "model": {
                "type": "minecraft:model",
                "model": "item/hidden"
              }
            }
          ]
        }
      },
      {
        "when": "permanent_passive",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "fallback": {
            "type": "minecraft:model",
            "model": "item/permanent_passive"
          },
          "cases": [
            {
              "when": [
                "firstperson_righthand",
                "firstperson_lefthand",
                "thirdperson_righthand",
                "thirdperson_lefthand"
              ],
              "model": {
                "type": "minecraft:model",
                "model": "item/hidden"
              }
            }
          ]
        }
      }
    ]
  }
}